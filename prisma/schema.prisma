// Pampa — esquema de datos (PostgreSQL / Supabase)
// DATABASE_URL: connection pooling de Supabase (Supavisor, puerto 6543, con ?pgbouncer=true)
// DIRECT_URL: conexión directa (puerto 5432) para migraciones.
// Categorías, roles y tipos van como String; las constantes viven en src/lib/domain.ts.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @default("")
  role         String   @default("WORKER") // OWNER | MANAGER | WORKER
  farmId       String?
  farm      Farm?    @relation(fields: [farmId], references: [id])
  createdAt DateTime @default(now())

  weighings  Weighing[]
  treatments Treatment[]
  rations    Ration[]
  movements  Movement[]
}

model Farm {
  id        String   @id @default(cuid())
  name      String
  location  String?
  hectares  Float?
  createdAt DateTime @default(now())

  users    User[]
  paddocks Paddock[]
  lots     Lot[]
  owners   Owner[]
  seasons  Season[]
  expenses Expense[]
}

// Campaña / ejercicio: agrupa el histórico del campo por ciclo (no necesariamente año calendario).
model Season {
  id        String    @id @default(cuid())
  name      String // ej. "Campaña 2025/26"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean   @default(false)
  closedAt  DateTime? // cuando se cierra el ejercicio
  farmId    String
  farm      Farm         @relation(fields: [farmId], references: [id])
  close     SeasonClose?
  createdAt DateTime     @default(now())

  @@index([farmId, startDate])
}

// Cierre de campaña: foto CONGELADA de los números clave al cerrar el ejercicio.
// Inmutable: guarda los precios y el reparto que regían entonces (no se recalcula).
model SeasonClose {
  id              String   @id @default(cuid())
  seasonId        String   @unique
  season          Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  closedAt        DateTime @default(now())
  headCount       Int // stock activo al cierre
  totalKg         Int // kg vivos del rodeo
  herdValue       Int // valor estimado
  salesQty        Int
  salesAmount     Int
  purchasesQty    Int
  purchasesAmount Int
  feedCost        Int
  vetCost         Int
  margin          Int // margen total repartible
  prices          Json // { STEER, COW, CALF } vigentes al cierre
  ownerSplit      Json // [{ name, kg, value, margin }] congelado
}

// Socio del campo. Su participación (Share) puede ser global (lotId null) o por lote.
model Owner {
  id        String   @id @default(cuid())
  name      String
  farmId    String
  farm      Farm     @relation(fields: [farmId], references: [id])
  shares    Share[]
  createdAt DateTime @default(now())
}

model Share {
  id       String  @id @default(cuid())
  ownerId  String
  owner    Owner   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  lotId    String? // null = participación global por defecto del establecimiento
  lot      Lot?    @relation(fields: [lotId], references: [id], onDelete: Cascade)
  sharePct Int // 0–100
}

model Paddock {
  id       String  @id @default(cuid())
  name     String
  hectares Float?
  farmId   String
  farm     Farm    @relation(fields: [farmId], references: [id])
  lots     Lot[]
}

model Lot {
  id        String   @id @default(cuid())
  name      String
  category  String // COW | STEER | CALF
  farmId    String
  farm      Farm     @relation(fields: [farmId], references: [id])
  paddockId String?
  paddock   Paddock? @relation(fields: [paddockId], references: [id])
  createdAt DateTime @default(now())

  animals    Animal[]
  weighings  Weighing[]
  rations    Ration[]
  treatments Treatment[]
  movements  Movement[]
  shares     Share[]
  events     HerdEvent[]
  expenses   Expense[]
}

model Animal {
  id        String    @id @default(cuid())
  tag       String // caravana visual
  rfid      String? // chip electrónico
  category  String // COW | STEER | CALF
  sex       String? // M | F
  birthDate DateTime?
  status    String    @default("ACTIVE") // ACTIVE | SOLD | DEAD
  // Egreso: el animal no se borra, queda con sus datos de salida para el histórico.
  exitDate    DateTime?
  exitReason  String? // SOLD | DEAD
  exitWeightKg Float? // peso al egreso (último pesaje)
  exitPriceArs Int? // $ de venta (0 en bajas)
  lotId     String
  lot       Lot       @relation(fields: [lotId], references: [id])
  createdAt DateTime  @default(now())

  weighings Weighing[]

  @@unique([tag])
}

model Weighing {
  id          String   @id @default(cuid())
  weightKg    Float
  date        DateTime
  animalId    String
  animal      Animal   @relation(fields: [animalId], references: [id])
  lotId       String
  lot         Lot      @relation(fields: [lotId], references: [id])
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([animalId, date])
}

model FeedIngredient {
  id           String  @id @default(cuid())
  name         String // Maíz, Silo de maíz, Expeller de soja...
  type         String // CARB | FIBER | PROTEIN
  dryMatterPct Float // % materia seca
  proteinPct   Float // % proteína bruta
  energyMcal   Float // EM Mcal/kg MS
  costPerKg    Int // ARS por kg (entero)

  rationItems RationItem[]
}

model Ration {
  id             String       @id @default(cuid())
  name           String
  effectiveFrom  DateTime
  effectiveTo    DateTime? // null = vigente; se completa cuando se carga una ración nueva para el lote
  kgPerDay       Float // kg totales de mezcla entregados por día al lote (el kg/cabeza se calcula)
  lotId          String
  lot            Lot          @relation(fields: [lotId], references: [id])
  createdById    String?
  createdBy      User?        @relation(fields: [createdById], references: [id])
  createdAt      DateTime     @default(now())
  items          RationItem[]
}

model RationItem {
  id           String         @id @default(cuid())
  rationId     String
  ration       Ration         @relation(fields: [rationId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   FeedIngredient @relation(fields: [ingredientId], references: [id])
  percentage   Float // % sobre la mezcla
}

model Treatment {
  id            String   @id @default(cuid())
  name          String
  type          String // VACCINE | ANTIPARASITIC | VITAMIN | OTHER
  date          DateTime
  status        String   @default("SCHEDULED") // SCHEDULED | PENDING | DONE
  withdrawalDays Int     @default(0) // período de carencia
  cost          Int      @default(0) // ARS
  lotId         String
  lot           Lot      @relation(fields: [lotId], references: [id])
  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
}

// Evento de manejo (no es un tratamiento con costo): vacunación, tacto, destete, etc.
// Registro flexible: un valor numérico cuyo significado depende del tipo (% preñez, kg, dosis…).
model HerdEvent {
  id          String   @id @default(cuid())
  type        String // VACCINATION | PALPATION | WEANING | CASTRATION | BRANDING | OTHER
  date        DateTime
  lotId       String
  lot         Lot      @relation(fields: [lotId], references: [id])
  headCount   Int? // cabezas involucradas
  value       Float? // dato/resultado (ej. % preñez en tacto, kg promedio en destete)
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([lotId, date])
}

// Gasto detallado (hoy de sanidad). Se suma al costo veterinario en Economía.
model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  category    String // SANIDAD (preparado para más categorías)
  concept     String // detalle del gasto
  amount      Int // ARS
  lotId       String?
  lot         Lot?     @relation(fields: [lotId], references: [id])
  farmId      String
  farm        Farm     @relation(fields: [farmId], references: [id])
  createdById String?
  createdAt   DateTime @default(now())

  @@index([category, date])
}

model Movement {
  id          String   @id @default(cuid())
  type        String // PURCHASE | SALE | BIRTH | DEATH | RECATEGORIZATION
  quantity    Int
  amount      Int      @default(0) // ARS total (compra/venta)
  date        DateTime
  note        String?
  lotId       String
  lot         Lot      @relation(fields: [lotId], references: [id])
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

// Cotización de hacienda traída automáticamente de una fuente pública (cron diario).
// Un registro por categoría por corrida → queda histórico para graficar evolución.
model MarketPrice {
  id         String   @id @default(cuid())
  source     String // MAG_CANUELAS
  category   String // STEER | COW | CALF (normalizado a las categorías de la app)
  label      String // etiqueta de la fuente, ej. "Novillos"
  pricePerKg Int // ARS por kg vivo (promedio ponderado por cabezas)
  refDate    DateTime // fecha de los precios según la fuente
  fetchedAt  DateTime @default(now())

  @@index([category, fetchedAt])
}

// Precio manual por categoría: si existe, pisa al automático del mercado.
model PriceSetting {
  id         String   @id @default(cuid())
  category   String   @unique // STEER | COW | CALF
  pricePerKg Int // ARS por kg vivo, fijado a mano por el dueño
  updatedAt  DateTime @updatedAt
}

// Salud de cada fuente automática de precios. El cron la actualiza en cada corrida.
// Si ok=false, la app avisa al usuario que está viendo el último valor guardado.
model SourceStatus {
  id        String    @id @default(cuid())
  source    String    @unique // MAG_CANUELAS
  ok        Boolean   @default(true)
  lastOkAt  DateTime? // último scrapeo exitoso
  lastTryAt DateTime  @default(now())
  message   String? // detalle del error cuando falla
}
