# Pampa — variables de entorno

# Supabase Postgres
# DATABASE_URL: usar el "Connection pooling" (Supavisor, puerto 6543) para el runtime.
#   Agregar al final: ?pgbouncer=true&connection_limit=1
# DIRECT_URL: usar la "Direct connection" (puerto 5432) para migraciones.
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# Secreto de sesión (firmado HMAC). En prod ya está en Vercel.
AUTH_SECRET="genera-uno-con: openssl rand -hex 32"
